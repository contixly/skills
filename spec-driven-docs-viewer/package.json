{
  "name": "@contixly/spec-driven-docs-viewer",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "spec-driven-docs-viewer": "./dist/cli.js"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "dev": "vite",
    "check": "tsc -p tsconfig.json --noEmit",
    "publish:package": "./scripts/publish.sh"
  },
  "dependencies": {
    "express": "^4.21.2",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
